<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_todo_list_list" model="ir.ui.view">
        <field name="name">todo.list.list.view</field>
        <field name="model">todo.list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="tag_ids" widget="many2many_tags"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_todo_list_form" model="ir.ui.view">
        <field name="name">todo.list.form.view</field>
        <field name="model">todo.list</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start_progress" type="object" string="Start Progress" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_mark_complete" type="object" string="DONE" class="btn-primary" invisible="state != 'in_progress' or not all_lines_done"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,complete"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" required="1" readonly="state == 'complete'"/>
                            <field name="tag_ids" widget="many2many_tags" readonly="state == 'complete'"/>
                        </group>
                        <group>
                            <field name="start_date" required="1" readonly="state == 'complete'"/>
                            <field name="end_date" required="1" readonly="state == 'complete'"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="todo_items" string="List">
                            <field name="line_ids" readonly="state == 'complete'">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="is_done" string="Is Complete" column_invisible="parent.state != 'in_progress'"/>
                                </list>
                            </field>
                        </page>
                        <page name="attendee" string="Attendee">
                            <field name="attendee_ids" readonly="state == 'complete'">
                                <list editable="bottom">
                                    <field name="user_id" options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_todo_list" model="ir.actions.act_window">
        <field name="name">Todo List</field>
        <field name="res_model">todo.list</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_todo_list_uncomplete" model="ir.actions.act_window">
        <field name="name">Todo List Uncomplete</field>
        <field name="res_model">todo.list</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '!=', 'complete')]</field>
    </record>

    <record id="action_todo_list_complete" model="ir.actions.act_window">
        <field name="name">Todo List Complete</field>
        <field name="res_model">todo.list</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'complete')]</field>
    </record>
</odoo>
